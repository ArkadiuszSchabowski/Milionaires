<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]Czy zostaniesz milionerem?</title>
    <link rel="stylesheet" href="~/css/globalSite.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/leftContainer.css" />
    <link rel="stylesheet" href="~/css/rightContainer.css" />
    <link rel="stylesheet" href="~/css/scores.css" />
</head>
<body>
    <header>
        <a asp-area="" asp-controller="Home" asp-action="Index">Nowa gra</a>
        <a asp-area="" asp-controller="Home" asp-action="Scores">Wyniki</a>
        <a asp-area="" asp-controller="Home" asp-action="Settings">Ustawienia</a>
        <a asp-area="" asp-controller="Home" asp-action="Information">Informacje</a>
    </header>
    <div id="globalContainer">
    <main role="main">
        @RenderBody()
    </main>
    </div>
    <footer></footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
